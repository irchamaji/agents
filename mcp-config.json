{
  "mcpServers": {
    "filesystem": {
      "command": "bunx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-filesystem",
        "/Users/ircham/.agents",
        "/Users/ircham/"
      ]
    },
    "agent-skills": {
      "command": "bunx",
      "args": [
        "-y",
        "@google/gemini-cli-mcp-server",
        "--skills-path",
        "/Users/ircham/.agents/skills"
      ]
    }
  },
  "preferences": {
    "coworkWebSearchEnabled": true,
    "coworkScheduledTasksEnabled": false,
    "ccdScheduledTasksEnabled": false
  }
}